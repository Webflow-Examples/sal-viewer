{
	"compatibility_date": "2026-04-28",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "sal_tool_app",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"kv_namespaces": [
		{
			"binding": "SESSIONS",
			"id": "local"
		}
	]
}